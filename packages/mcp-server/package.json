{
  "name": "promptonomicon-mcp",
  "version": "1.0.0",
  "description": "Promptonomicon to-do manager MCP server",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "promptonomicon-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:integration": "tsx __tests__/integration-agent.test.ts",
    "test:integration:verbose": "tsx __tests__/integration-agent.test.ts --verbose",
    "start": "tsx src/cli.ts"
  },
  "keywords": [
    "mcp",
    "todo",
    "promptonomicon"
  ],
  "author": "trianglegrrl",
  "license": "MIT",
  "dependencies": {
    "fastmcp": "^3.23.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@openai/agents": "^0.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
